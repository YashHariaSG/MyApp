# Environment for Xcode script phases (Bundle React Native, etc.).
# Local overrides: ios/.xcode.env.local (gitignored)

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"

# Use Node from repo .nvmrc (MyApp requires >= 22.11 for Metro util.styleText)
RN_ROOT="$PODS_ROOT/../.."
if [ -f "$RN_ROOT/.nvmrc" ] && command -v nvm >/dev/null 2>&1; then
  cd "$RN_ROOT" && nvm use --silent
fi

export NODE_BINARY=$(command -v node)
